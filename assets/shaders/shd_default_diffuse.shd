{
    "name": "Default Diffuse",
    "vertex_shader": [
        "#version 330 core",
        "layout (location=0) in vec3 pos;",
        "layout (location=1) in vec3 normal;",
        "layout (location=2) in vec2 t_coord;",
        "void main() {",
        "gl_Position = vec4(pos,1.0);",
        "}"
    ],
    "fragment_shader": [
        "#version 330 core",
        "out vec4 frag_color;",
        "void main() {",
        "frag_color = vec4(1.0,0.0,0.0,1.0);",
        "}"
    ]
}
